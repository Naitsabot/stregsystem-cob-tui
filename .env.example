# Stregsystem API Configuration
# Copy this file to .env and modify as needed

# Full URL to the stregsystem API
STREGSYSTEM_URL=https://stregsystem.fklub.dk

# Host address (deprecated, use STREGSYSTEM_URL instead)
STREGSYSTEM_HOST=127.0.0.1

# Port number (deprecated, use STREGSYSTEM_URL instead)
STREGSYSTEM_PORT=8000

# Logging level: 0=off, 1=error, 2=warn, 3=info, 4=debug, 5=trace
STREGSYSTEM_LOG_LEVEL=4

# Log sink: STDERR, STDOUT, or FILE
STREGSYSTEM_LOG_SINK=STDERR

# Log file path (if set, logs are appended here and sink is FILE)
STREGSYSTEM_LOG_FILE=/tmp/stregsystem.log